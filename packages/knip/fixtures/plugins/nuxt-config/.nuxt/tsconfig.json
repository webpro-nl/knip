{
  "compilerOptions": {
    "paths": {
      "nuxt": ["../node_modules/nuxt"],
      "~": [".."],
      "~/*": ["../*"],
      "@": [".."],
      "@/*": ["../*"],
      "~~": [".."],
      "~~/*": ["../*"],
      "@@": [".."],
      "@@/*": ["../*"],
      "#build": ["."],
      "#build/*": ["./*"],
      "#components": ["./components"]
    },
    "module": "ESNext",
    "moduleResolution": "Bundler"
  }
}
