---
import { formatTimestamp, type PostWithUser, replaceShortenedUrls } from '../util/post.js';

const post: PostWithUser = replaceShortenedUrls(Astro.props.data);
---

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    line-height: 1.2;
  }
  .profile {
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    border: 1px solid var(--sl-color-gray-5);
    object-fit: cover;
    flex-shrink: 0;
  }
  .name {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .real {
    color: var(--sl-color-white);
    font-weight: 600;
    font-size: 0.95rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .screen {
    color: var(--sl-color-gray-3);
    font-size: 0.8125rem;
    font-family: var(--sl-font-system-mono);
  }
  .text {
    color: var(--sl-color-white);
    font-size: 1rem;
    line-height: 1.55;
    margin: 0 !important;
  }
  .timestamp {
    margin: auto 0 0 !important;
    padding-top: 0.75rem;
    border-top: 1px solid var(--sl-color-gray-5);
    font-size: 0.8125rem;
    color: var(--sl-color-gray-3);
    font-family: var(--sl-font-system-mono);
  }
  .timestamp a {
    color: inherit !important;
    text-decoration: none !important;
  }
  .timestamp a:is(:hover, :focus-visible) {
    color: var(--sl-color-accent-high) !important;
  }
</style>

{
  post && (
    <div class="card">
      <header>
        <img class="profile" src={post.user.profile_image_url} alt={post.user.name} />
        <div class="name">
          <span class="real">{post.user.name}</span>
          <span class="screen">@{post.user.username}</span>
        </div>
      </header>
      <p class="text" set:html={post.text.trim().replace(/\n/g, '<br />')} />
      <p class="timestamp">
        <a
          href={`${post.url ? post.url : post.id.length > 17 ? `https://twitter.com/${post.user.username}/status/${post.id}` : `https://bsky.app/profile/${post.user.username}/post/${post.id}`}`}>
          {formatTimestamp(post.created_at)}
        </a>
      </p>
    </div>
  )
}
