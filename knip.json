{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["!templates/**"]
    },
    "packages/knip": {
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts",
        "!src/util/empty.ts",
        "!**/_template/**"
      ],
      "ignoreDependencies": ["prettier"]
    },
    "packages/docs": {
      "entry": ["{remark,scripts}/*.ts"]
    },
    "packages/vscode-knip": {
      "entry": ["src/index.js!", "scripts/*.js", "test/*.mjs"],
      "ignoreDependencies": ["vscode!"]
    }
  }
}
